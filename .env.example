# ── Copy this to .env and fill in your values ──────────────────────────────
# Then load with: export $(cat .env | xargs)   OR use python-dotenv

# Flask
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False

# RapidAPI — Indian Railway IRCTC API
# Sign up free at: https://rapidapi.com/IRCTC1/api/indian-railway-irctc
RAPIDAPI_KEY=your_rapidapi_key_here

# Gmail SMTP (use App Password, not your main password)
# Guide: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=IRCTC Tracker <your_gmail@gmail.com>

# Optional overrides
# SCHEDULER_INTERVAL_MINUTES=60
